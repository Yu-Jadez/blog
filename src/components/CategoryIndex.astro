---
import PostCard from './PostCard.astro';
import { BASE } from '../consts';
import { stripMarkdown } from '../utils';

interface SubCategory {
  name: string;
  path: string;
  count: number;
}

interface Props {
  section: 'daily' | 'notes';
  title: string;
  description?: string;
  breadcrumbs: { label: string; href: string }[];
  subCategories: SubCategory[];
  posts: any[];
}

const { section, title, description, breadcrumbs, subCategories, posts } = Astro.props;
const sectionLabel = section === 'daily' ? '日常' : '笔记';
const sectionBase = section === 'daily' ? '/daily' : '/notes';
---

<article>
  <!-- 面包屑导航 -->
  <nav class="flex items-center gap-2 text-sm text-[#666666] dark:text-gray-400 mb-6 flex-wrap">
    {breadcrumbs.map((crumb, i) => (
      <>
        {i > 0 && <span class="text-gray-300 dark:text-gray-600">/</span>}
        <a href={crumb.href} class="hover:text-primary dark:hover:text-red-400 transition-colors">
          {crumb.label}
        </a>
      </>
    ))}
  </nav>

  <!-- 分类标题 -->
  <h1 class="text-2xl sm:text-3xl font-bold text-[#1A1A1A] mb-2 pb-3 sm:pb-4 border-b-2 border-primary dark:text-white dark:border-[#b05223]">
    {title}
  </h1>
  {description && (
    <p class="text-sm sm:text-base text-[#666666] mb-6 sm:mb-8 dark:text-gray-400">{description}</p>
  )}

  <!-- 子分类 -->
  {subCategories.length > 0 && (
    <div class="mb-8">
      <h2 class="text-lg font-semibold text-[#1A1A1A] mb-3 dark:text-white">📁 分类</h2>
      <div class="grid gap-3">
        {subCategories.map((cat) => (
          <a
            href={`${BASE}${sectionBase}/${cat.path}/`}
            class="flex items-center gap-3 bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow p-4 border border-gray-100 dark:bg-[#0a1f47] dark:border-gray-700 no-underline"
          >
            <span class="text-2xl">📁</span>
            <div class="flex-1">
              <span class="font-medium text-[#1A1A1A] dark:text-white">{cat.name}</span>
              <span class="text-xs text-[#666666] dark:text-gray-400 ml-2">{cat.count} 篇</span>
            </div>
            <span class="text-gray-300 dark:text-gray-600">→</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- 文章列表 -->
  {posts.length > 0 ? (
    <div>
      {subCategories.length > 0 && (
        <h2 class="text-lg font-semibold text-[#1A1A1A] mb-3 dark:text-white">📝 文章</h2>
      )}
      <div class="grid gap-4">
        {posts.map((post) => {
          const slug = post.id.split('/').pop()!;
          return (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              href={`${BASE}${sectionBase}/${post.id}/`}
              excerpt={stripMarkdown(post.body ?? '')}
            />
          );
        })}
      </div>
    </div>
  ) : subCategories.length === 0 && (
    <div class="text-center py-16">
      <p class="text-4xl mb-4">📭</p>
      <p class="text-sm sm:text-base text-[#666666] dark:text-gray-400">这个分类下还没有文章</p>
    </div>
  )}
</article>
