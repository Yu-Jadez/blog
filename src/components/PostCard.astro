---
export interface Props {
  title: string;
  date: Date;
  href: string;
  excerpt?: string;
  type?: 'essay' | 'note';
}

const { title, date, href, excerpt } = Astro.props;
---

<article class="card border-l-4 border-primary-dark group pl-8 rounded-lg dark:bg-[#0a1f47] dark:border-black dark:shadow-[inset_0_2px_8px_rgba(0,0,0,0.4)] dark:py-10 dark:px-8">
  <a href={href} class="block no-underline text-inherit">
    <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors dark:text-white dark:group-hover:text-red-400">
      {title}
    </h3>
    <time datetime={date.toISOString()} class="text-sm text-[#666666] dark:text-gray-400">
      {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
    {excerpt && (
      <p class="mt-3 text-sm text-[#666666] line-clamp-2 dark:text-gray-400">{excerpt}</p>
    )}
  </a>
</article>
