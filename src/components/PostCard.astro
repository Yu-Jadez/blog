---
export interface Props {
  title: string;
  date: Date;
  href: string;
  excerpt?: string;
  type?: 'essay' | 'note';
}

const { title, date, href, excerpt, type = 'essay' } = Astro.props;

const accentClass = type === 'essay'
  ? 'border-l-4 border-primary'
  : 'border-t-2 border-primary/40';
---

<article class={`card ${accentClass} group`}>
  <a href={href} class="block no-underline text-inherit">
    <h3 class="text-lg font-semibold mb-2 group-hover:text-primary transition-colors">
      {title}
    </h3>
    <time datetime={date.toISOString()} class="text-sm text-[#666666]">
      {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
    {excerpt && (
      <p class="mt-3 text-sm text-[#666666] line-clamp-2">{excerpt}</p>
    )}
  </a>
</article>
