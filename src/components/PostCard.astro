---
export interface Props {
  title: string;
  date: Date;
  href: string;
  excerpt?: string;
  type?: 'essay' | 'note';
}

const { title, date, href, excerpt } = Astro.props;
---

<article class="bg-white shadow-md hover:shadow-lg transition-shadow border-l-4 border-primary-dark group py-5 sm:py-7 pl-5 sm:pl-8 pr-4 sm:pr-6 rounded-lg dark:bg-[#0a1f47] dark:border-black dark:shadow-[inset_0_2px_8px_rgba(0,0,0,0.4)]">
  <a href={href} class="block no-underline text-inherit overflow-hidden">
    <h3 class="text-base sm:text-lg font-semibold mb-1.5 sm:mb-2 group-hover:text-primary transition-colors dark:text-white dark:group-hover:text-red-400 break-words">
      {title}
    </h3>
    <time datetime={date.toISOString()} class="text-xs sm:text-sm text-[#666666] dark:text-gray-400">
      {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
    {excerpt && (
      <p class="mt-2 sm:mt-3 text-xs sm:text-sm text-[#666666] line-clamp-2 dark:text-gray-400 break-words">{excerpt}</p>
    )}
  </a>
</article>
