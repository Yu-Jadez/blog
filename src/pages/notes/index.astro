---
import Layout from '../../components/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { stripMarkdown } from '../../utils';
import { BASE } from '../../consts';

const notes = await getCollection('notes');
notes.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="笔记">
  <section>
    <h1 class="page-title">笔记 · Notes</h1>
    <p class="text-[#666666] mb-8 dark:text-gray-400">这里记录我的学习笔记，温故而知新。</p>

    {
      notes.length > 0 ? (
        <div class="grid gap-4">
          {notes.map((note) => (
            <PostCard
              title={note.data.title}
              date={note.data.date}
              href={`${BASE}/notes/${note.id}`}
              type="note"
              excerpt={stripMarkdown(note.body ?? '')}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-4xl mb-4">📭</p>
          <p class="text-[#666666] dark:text-gray-400">还没有笔记，去后台写一篇吧 ✍️</p>
        </div>
      )
    }
  </section>
</Layout>
