---
import Layout from '../../components/Layout.astro';
import { getCollection } from 'astro:content';
import { stripMarkdown } from '../../utils';
import { BASE } from '../../consts';

const notes = await getCollection('notes');

const topPosts = notes.filter(n => !n.id.includes('/') && !n.id.endsWith('/index'));
const catMap = new Map<string, { count: number; posts: any[]; subCats: Map<string, any> }>();
for (const n of notes) {
  const parts = n.id.split('/');
  if (parts.length >= 2 && !n.id.endsWith('/index')) {
    const cat = parts[0];
    if (!catMap.has(cat)) catMap.set(cat, { count: 0, posts: [], subCats: new Map() });
    const entry = catMap.get(cat)!;
    if (parts.length === 2) { entry.count++; entry.posts.push(n); }
    else if (parts.length >= 3) {
      // Nested folder
      const sub = parts[1];
      if (!entry.subCats.has(sub)) entry.subCats.set(sub, []);
      entry.subCats.get(sub)!.push(n);
    }
  }
}

topPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const items: { type: 'folder' | 'post'; id: string; data?: any }[] = [];
for (const [name, info] of catMap) items.push({ type: 'folder', id: name, data: info });
for (const p of topPosts) items.push({ type: 'post', id: p.id, data: p });
---

<Layout title="笔记">
  <section class="tree-section">
    <h1 class="text-2xl sm:text-3xl font-bold text-[#1A1A1A] mb-2 pb-3 sm:pb-4 border-b-2 border-primary dark:text-white dark:border-[#b05223]">笔记 · Notes</h1>
    <p class="text-sm sm:text-base text-[#666666] mb-8 dark:text-gray-400">这里记录我的学习笔记，温故而知新。</p>

    <!-- Tree container -->
    <div id="tree-root" class="tree-root">
      {items.map((item, i) => {
        const label = item.type === 'folder' ? item.id : (item.data?.data?.title || item.id);
        const iconItem = item.type === 'folder' ? '📁' : '📄';
        const count = item.type === 'folder' ? item.data.count : null;
        const dateStr = item.type === 'post' ? (item.data.data.date ? new Date(item.data.data.date).toLocaleDateString('zh-CN', {year:'numeric',month:'long',day:'numeric'}) : '') : '';
        const excerpt = item.type === 'post' ? stripMarkdown(item.data.body ?? '', 200) : '';

        const childrenJson = item.type === 'folder'
          ? JSON.stringify({
              posts: item.data.posts.map((p:any) => ({ type:'post', id:p.id, title:p.data.title, date:p.data.date })),
              subCats: [...item.data.subCats].map(([k,v]) => ({ type:'folder', name:k, posts: v.map((p:any) => ({ type:'post', id:p.id, title:p.data.title, date:p.data.date })) }))
            })
          : '';

        const idStr = item.id.replace(/'/g, "\\'");
        return (
          <div class="tree-node-wrapper">
            <button class="tree-node-btn" data-type={item.type} data-id={idStr}
              data-label={label} data-icon={iconItem}
              data-count={String(count || '')} data-date={dateStr}
              data-excerpt={excerpt}
              data-children={childrenJson}>
              <span class="node-icon">{iconItem}</span>
              <span class="node-label">{label}</span>
              {count !== null && <span class="node-count">{count}</span>}
            </button>
            {/* Branch children will be inserted here by JS */}
            <div class="tree-branch hidden"></div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  .tree-section { max-width: 700px; margin: 0 auto; }
  .tree-root { display: flex; flex-direction: column; gap: 8px; position: relative; align-items: flex-start; }
  .tree-node-wrapper { position: relative; display: flex; align-items: center; }

  .tree-node-btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 12px 24px; border-radius: 28px;
    border: 2px solid #e0e0e0; background: #fff;
    font-size: 15px; font-weight: 500; color: #1A1A1A;
    cursor: pointer; transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
    white-space: nowrap; font-family: inherit;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04); position: relative; z-index: 2;
  }
  .tree-node-btn:hover { border-color: #c0c0c0; box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
  .tree-node-btn.active {
    border-color: #E63946; background: #E63946; color: #fff;
    box-shadow: 0 6px 20px rgba(230,57,70,0.3);
  }
  .tree-node-btn.active .node-count { background: rgba(255,255,255,0.3); color: #fff; }
  .tree-node-btn.faded { opacity: 0.25; pointer-events: none; }

  .node-icon { font-size: 20px; }
  .node-label { max-width: 250px; overflow: hidden; text-overflow: ellipsis; }
  .node-count { font-size: 11px; background: #fde8ea; color: #E63946; padding: 2px 8px; border-radius: 10px; }

  /* Dark */
  .dark .tree-node-btn { background: #0a1f47; border-color: #2a4a6a; color: #ddd; }
  .dark .tree-node-btn:hover { border-color: #b05223; }
  .dark .tree-node-btn.active { background: #b05223; border-color: #b05223; color: #fff; }
  .dark .node-count { background: rgba(176,82,35,0.2); color: #c97a4a; }

  /* Branch tree */
  .tree-branch {
    margin-left: 24px; display: flex; flex-direction: column; gap: 6px;
    padding-left: 20px; border-left: 2px solid #e0e0e0;
    animation: branchIn 0.25s ease;
    min-width: 280px;
  }
  .dark .tree-branch { border-left-color: #3a5a7a; }
  @keyframes branchIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }

  .branch-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 8px 16px; border-radius: 20px;
    border: 1.5px solid #e8e8e8; background: #fafafa;
    font-size: 13px; font-weight: 500; color: #333;
    cursor: pointer; transition: all 0.2s; font-family: inherit; white-space: nowrap;
    text-decoration: none;
  }
  .branch-btn:hover { border-color: #E63946; background: #fff; }
  .branch-btn.is-folder { border-color: #f0c0a0; background: #fef5f0; color: #a0522d; }
  .branch-btn.is-folder:hover { border-color: #b05223; background: #fde8da; }
  .branch-btn a { text-decoration: none; color: inherit; }
  .dark .branch-btn { background: #061a35; border-color: #2a4a6a; color: #ccc; }
  .dark .branch-btn:hover { border-color: #b05223; }
  .dark .branch-btn.is-folder { border-color: #4a3020; background: #0d1f35; color: #c97a4a; }
  .dark .branch-btn.is-folder:hover { border-color: #b05223; background: #152540; }

  .branch-btn-icon { font-size: 16px; }
  .branch-btn-count { font-size: 10px; background: #eee; padding: 1px 6px; border-radius: 8px; color: #888; }
  .dark .branch-btn-count { background: #1a3050; color: #888; }

  .node-pin-hint { font-size: 11px; color: #999; margin-top: 4px; }

  /* Article preview card */
  .article-preview {
    padding: 16px 20px; background: #fff; border-radius: 12px;
    border: 1.5px solid #eee; min-width: 260px; max-width: 360px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06); animation: branchIn 0.25s ease;
  }
  .dark .article-preview { background: #0a1f47; border-color: #2a4a6a; }
  .article-preview h4 { font-size: 15px; font-weight: 700; margin-bottom: 4px; color: #1A1A1A; }
  .dark .article-preview h4 { color: #fff; }
  .article-preview .ap-date { font-size: 11px; color: #999; margin-bottom: 8px; }
  .article-preview .ap-excerpt { font-size: 13px; color: #666; line-height: 1.6; margin-bottom: 10px; }
  .dark .article-preview .ap-excerpt { color: #bbb; }
  .article-preview .ap-link { color: #E63946; font-size: 13px; font-weight: 600; text-decoration: none; }
  .dark .article-preview .ap-link { color: #c97a4a; }
</style>

<script>
  const B = '/blog';
  let pinnedId: string | null = null;
  let hoverTimer: ReturnType<typeof setTimeout>;

  function esc(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  function clearAll() {
    document.querySelectorAll('.tree-node-btn').forEach(b => { b.classList.remove('active', 'faded'); });
    document.querySelectorAll('.tree-branch').forEach(b => { b.classList.add('hidden'); b.innerHTML = ''; });
  }

  function showBranch(wrapper: HTMLElement, btn: HTMLElement, data: any) {
    const branch = wrapper.querySelector('.tree-branch')!;
    branch.classList.remove('hidden');
    branch.innerHTML = '';

    // Sub-folders
    if (data.subCats) {
      data.subCats.forEach((sc: any) => {
        const b = document.createElement('button');
        b.className = 'branch-btn is-folder';
        b.innerHTML = `<span class="branch-btn-icon">📁</span>${esc(sc.name)}<span class="branch-btn-count">${sc.posts.length}</span>`;
        b.onclick = (e) => {
          e.stopPropagation();
          window.location.href = `${B}/notes/${btn.dataset.id}/${sc.name}/`;
        };
        branch.appendChild(b);
      });
    }

    // Posts in folder
    if (data.posts) {
      data.posts.forEach((p: any) => {
        const b = document.createElement('a');
        b.className = 'branch-btn';
        b.href = `${B}/notes/${p.id}`;
        b.innerHTML = `<span class="branch-btn-icon">📄</span>${esc(p.title)}`;
        branch.appendChild(b);
      });
    }
  }

  function showPreview(wrapper: HTMLElement, btn: HTMLElement) {
    const branch = wrapper.querySelector('.tree-branch')!;
    branch.classList.remove('hidden');
    branch.innerHTML = `
      <div class="article-preview">
        <h4>${esc(btn.dataset.label || '')}</h4>
        <div class="ap-date">${esc(btn.dataset.date || '')}</div>
        <div class="ap-excerpt">${esc(btn.dataset.excerpt || '')}</div>
        <a href="${B}/notes/${btn.dataset.id}" class="ap-link">阅读全文 →</a>
      </div>`;
  }

  function focus(btn: HTMLElement) {
    clearAll();
    const wrapper = btn.closest('.tree-node-wrapper')!;
    document.querySelectorAll('.tree-node-btn').forEach(b => {
      if (b !== btn) b.classList.add('faded');
    });
    btn.classList.add('active');

    if (btn.dataset.type === 'folder') {
      try {
        const data = JSON.parse(btn.dataset.children || '{}');
        showBranch(wrapper, btn, data);
      } catch(e) {}
    } else {
      showPreview(wrapper, btn);
    }
  }

  function unfocus() {
    if (pinnedId) {
      clearAll();
      const pBtn = document.querySelector(`.tree-node-btn[data-id="${CSS.escape(pinnedId)}"]`) as HTMLElement;
      if (pBtn) focus(pBtn);
      return;
    }
    clearAll();
  }

  document.querySelectorAll('.tree-node-btn').forEach(btn => {
    btn.addEventListener('mouseenter', () => { clearTimeout(hoverTimer); focus(btn as HTMLElement); });
    btn.addEventListener('mouseleave', () => {
      hoverTimer = setTimeout(() => { if (!pinnedId || btn.dataset.id !== pinnedId) unfocus(); }, 250);
    });
    btn.addEventListener('click', (e) => {
      if (btn.dataset.type === 'folder') {
        e.preventDefault();
        if (pinnedId === btn.dataset.id) {
          pinnedId = null; unfocus();
        } else {
          pinnedId = btn.dataset.id!;
          const wrapper = btn.closest('.tree-node-wrapper')!;
          focus(btn as HTMLElement);
          // Show pin hint
          const branch = wrapper.querySelector('.tree-branch')!;
          const hint = document.createElement('div');
          hint.className = 'node-pin-hint';
          hint.textContent = '已固定 · 点击文件夹取消';
          branch.appendChild(hint);
        }
      } else {
        window.location.href = `${B}/notes/${btn.dataset.id}`;
      }
    });

    // Hover on branch items keeps focus
    const wrapper = btn.closest('.tree-node-wrapper')!;
    wrapper.addEventListener('mouseenter', () => { clearTimeout(hoverTimer); });
    wrapper.addEventListener('mouseleave', () => {
      hoverTimer = setTimeout(() => { if (!pinnedId) unfocus(); }, 300);
    });
  });
</script>
