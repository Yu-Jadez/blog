---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import CategoryIndex from '../../components/CategoryIndex.astro';
import { BASE } from '../../consts';
import { stripMarkdown } from '../../utils';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  const nested = notes.filter(n => n.id.includes('/') && !n.id.endsWith('/index'));
  const pathSet = new Set<string>();
  for (const n of nested) {
    const parts = n.id.split('/');
    for (let i = 2; i <= parts.length; i++) {
      pathSet.add(parts.slice(0, i).join('/'));
    }
  }
  return [...pathSet].map((fullPath) => {
    return { params: { slug: fullPath }, props: { fullPath } };
  });
}

const { fullPath } = Astro.props as { fullPath: string };
const notes = await getCollection('notes');
const slugParts = fullPath.split('/');
const matchingPost = notes.find(n => n.id === fullPath);
const hasChildren = notes.some(n => n.id.startsWith(fullPath + '/') && n.id !== fullPath + '/index');
const isPost = matchingPost && !hasChildren;

let pageTitle = '';
let ContentCmp: any = null;
let postData: any = null;
let parentCat = '';
let backLabel = '笔记';
let catTitle = '';
let catDesc: string | undefined;
let catSubs: { name: string; path: string; count: number }[] = [];
let catPosts: any[] = [];
let catCrumbs: { label: string; href: string }[] = [];

if (isPost) {
  const rendered = await render(matchingPost);
  ContentCmp = rendered.Content;
  postData = matchingPost.data;
  pageTitle = matchingPost.data.title;
  parentCat = slugParts.slice(0, -1).join('/');
  backLabel = parentCat ? slugParts[slugParts.length - 2] : '笔记';
} else {
  const indexNote = notes.find(n => n.id === `${fullPath}/index`);
  catTitle = indexNote?.data.title || slugParts[slugParts.length - 1];
  catDesc = indexNote?.body ? stripMarkdown(indexNote.body ?? '', 200) : undefined;
  pageTitle = catTitle;

  const subCats = new Map<string, number>();
  const posts: any[] = [];
  const prefix = fullPath + '/';
  for (const n of notes) {
    if (!n.id.startsWith(prefix)) continue;
    const relative = n.id.slice(prefix.length);
    const parts = relative.split('/');
    if (parts.length === 1 && relative !== 'index') { posts.push(n); }
    else if (parts.length >= 2) { subCats.set(parts[0], (subCats.get(parts[0]) || 0) + 1); }
  }
  posts.sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());
  catPosts = posts;
  catSubs = [...subCats].map(([name, count]) => ({ name, path: `${fullPath}/${name}`, count }));
  catCrumbs = [{ label: '笔记', href: `${BASE}/notes` }];
  for (let i = 0; i < slugParts.length; i++) {
    catCrumbs.push({ label: slugParts[i], href: `${BASE}/notes/${slugParts.slice(0, i + 1).join('/')}/` });
  }
}
---

<Layout title={pageTitle}>
  {isPost ? (
    <article class="max-w-prose mx-auto">
      <header class="mb-8">
        <a href={`${BASE}/notes${parentCat ? '/' + parentCat : ''}`} class="text-sm text-primary hover:text-primary-dark mb-4 inline-block dark:text-red-400 dark:hover:text-red-300">← 返回{backLabel}</a>
        <h1 class="text-2xl sm:text-3xl font-bold text-[#1A1A1A] mb-3 dark:text-white">{postData.title}</h1>
        <div class="flex items-center gap-3 text-sm text-[#666666] dark:text-gray-400">
          <time datetime={postData.date.toISOString()}>
            {postData.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {postData.tags?.length > 0 && <span>·</span>}
          <div class="flex gap-2">
            {postData.tags?.map((tag: string) => (
              <span class="inline-block px-2 py-0.5 bg-primary/10 text-primary text-xs rounded-full dark:bg-red-500/20 dark:text-red-300">{tag}</span>
            ))}
          </div>
        </div>
      </header>
      <div class="prose prose-lg max-w-none prose-a:text-primary prose-a:no-underline hover:prose-a:text-primary-dark dark:prose-invert">
        <ContentCmp />
      </div>
      <footer class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-700">
        <a href={`${BASE}/notes`} class="text-primary hover:text-primary-dark dark:text-red-400 dark:hover:text-red-300">← 返回笔记</a>
      </footer>
    </article>
  ) : (
    <CategoryIndex section="notes" title={catTitle} description={catDesc} breadcrumbs={catCrumbs} subCategories={catSubs} posts={catPosts} />
  )}
</Layout>
