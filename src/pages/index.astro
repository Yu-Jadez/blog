---
import Layout from '../components/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, HERO, BASE } from '../consts';
import { getCollection } from 'astro:content';
import { stripMarkdown } from '../utils';

const essays = (await getCollection('essays'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const notes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="主页">
  <!-- Hero Section -->
  <section class="py-16 sm:py-24 flex items-center justify-between gap-8">
    <div class="flex-1 text-left">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4 text-[#1A1A1A]">
        {HERO.greeting}
      </h1>
      <p class="text-lg text-[#666666] max-w-md">
        {HERO.description}
      </p>
      <div class="mt-8 flex items-center gap-4">
        <a href={`${BASE}/daily`} class="btn-primary">去看随笔</a>
        <a href={`${BASE}/fun`} class="inline-block px-6 py-2.5 border-2 border-primary text-primary rounded-lg font-medium hover:bg-primary hover:text-white transition-colors">
          玩个小游戏
        </a>
      </div>
    </div>
    <div class="hidden sm:block flex-shrink-0">
      <img src={`${BASE}/images/t1.jpg`} alt="avatar" class="w-28 h-28 rounded-full object-cover shadow-lg" />
    </div>
  </section>

  <!-- Recent Essays -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-[#1A1A1A]">
        近期随笔
      </h2>
      <a href={`${BASE}/daily`} class="text-sm text-primary hover:text-primary-dark">查看全部 →</a>
    </div>
    {
      essays.length > 0 ? (
        <div class="grid gap-4">
          {essays.map((essay) => (
            <PostCard
              title={essay.data.title}
              date={essay.data.date}
              href={`${BASE}/daily/${essay.id}`}
              type="essay"
              excerpt={stripMarkdown(essay.body ?? '')}
            />
          ))}
        </div>
      ) : (
        <p class="text-[#666666] text-sm">暂无随笔，去后台写一篇吧 ✍️</p>
      )
    }
  </section>

  <!-- Recent Notes -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-[#1A1A1A]">
        最近笔记
      </h2>
      <a href={`${BASE}/notes`} class="text-sm text-primary hover:text-primary-dark">查看全部 →</a>
    </div>
    {
      notes.length > 0 ? (
        <div class="grid gap-4">
          {notes.map((note) => (
            <PostCard
              title={note.data.title}
              date={note.data.date}
              href={`${BASE}/notes/${note.id}`}
              type="note"
              excerpt={stripMarkdown(note.body ?? '')}
            />
          ))}
        </div>
      ) : (
        <p class="text-[#666666] text-sm">暂无笔记，去后台写一篇吧 ✍️</p>
      )
    }
  </section>
</Layout>
