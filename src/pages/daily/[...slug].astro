---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import CategoryIndex from '../../components/CategoryIndex.astro';
import { BASE } from '../../consts';
import { stripMarkdown } from '../../utils';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  const nested = essays.filter(e => e.id.includes('/') && !e.id.endsWith('/index'));
  const pathSet = new Set<string>();
  for (const e of nested) {
    const parts = e.id.split('/');
    // 只生成多级路径（2段以上），单级由 [slug].astro 处理
    for (let i = 2; i <= parts.length; i++) {
      pathSet.add(parts.slice(0, i).join('/'));
    }
  }
  return [...pathSet].map((fullPath) => {
    return { params: { slug: fullPath }, props: { fullPath } };
  });
}

const { fullPath } = Astro.props as { fullPath: string };
const essays = await getCollection('essays');
const slugParts = fullPath.split('/');
const matchingPost = essays.find(e => e.id === fullPath);
const hasChildren = essays.some(e => e.id.startsWith(fullPath + '/') && e.id !== fullPath + '/index');
const isPost = matchingPost && !hasChildren;

let pageTitle = '';
let ContentCmp: any = null;
let postData: any = null;
let parentCat = '';
let backLabel = '日常';
let catTitle = '';
let catDesc: string | undefined;
let catSubs: { name: string; path: string; count: number }[] = [];
let catPosts: any[] = [];
let catCrumbs: { label: string; href: string }[] = [];

if (isPost) {
  const rendered = await render(matchingPost);
  ContentCmp = rendered.Content;
  postData = matchingPost.data;
  pageTitle = matchingPost.data.title;
  parentCat = slugParts.slice(0, -1).join('/');
  backLabel = parentCat ? slugParts[slugParts.length - 2] : '日常';
} else {
  const indexEssay = essays.find(e => e.id === `${fullPath}/index`);
  catTitle = indexEssay?.data.title || slugParts[slugParts.length - 1];
  catDesc = indexEssay?.body ? stripMarkdown(indexEssay.body ?? '', 200) : undefined;
  pageTitle = catTitle;

  const subCats = new Map<string, number>();
  const posts: any[] = [];
  const prefix = fullPath + '/';
  for (const e of essays) {
    if (!e.id.startsWith(prefix)) continue;
    const relative = e.id.slice(prefix.length);
    const parts = relative.split('/');
    if (parts.length === 1 && relative !== 'index') { posts.push(e); }
    else if (parts.length >= 2) { subCats.set(parts[0], (subCats.get(parts[0]) || 0) + 1); }
  }
  posts.sort((a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf());
  catPosts = posts;
  catSubs = [...subCats].map(([name, count]) => ({ name, path: `${fullPath}/${name}`, count }));
  catCrumbs = [{ label: '日常', href: `${BASE}/daily` }];
  for (let i = 0; i < slugParts.length; i++) {
    catCrumbs.push({ label: slugParts[i], href: `${BASE}/daily/${slugParts.slice(0, i + 1).join('/')}/` });
  }
}
---

<Layout title={pageTitle}>
  {isPost ? (
    <article class="max-w-prose mx-auto">
      <header class="mb-8">
        <a href={`${BASE}/daily${parentCat ? '/' + parentCat : ''}`} class="text-sm text-primary hover:text-primary-dark mb-4 inline-block dark:text-red-400 dark:hover:text-red-300">← 返回{backLabel}</a>
        <h1 class="text-2xl sm:text-3xl font-bold text-[#1A1A1A] mb-3 dark:text-white">{postData.title}</h1>
        <time datetime={postData.date.toISOString()} class="text-sm text-[#666666] dark:text-gray-400">
          {postData.date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </header>
      <div class="prose prose-lg max-w-none prose-a:text-primary prose-a:no-underline hover:prose-a:text-primary-dark dark:prose-invert">
        <ContentCmp />
      </div>
      <footer class="mt-12 pt-6 border-t border-gray-200 dark:border-gray-700">
        <a href={`${BASE}/daily`} class="text-primary hover:text-primary-dark dark:text-red-400 dark:hover:text-red-300">← 返回日常</a>
      </footer>
    </article>
  ) : (
    <CategoryIndex section="daily" title={catTitle} description={catDesc} breadcrumbs={catCrumbs} subCategories={catSubs} posts={catPosts} />
  )}
</Layout>
