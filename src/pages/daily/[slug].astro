---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { BASE } from '../../consts';

export async function getStaticPaths() {
  const essays = await getCollection('essays');
  return essays.map((essay) => ({
    params: { slug: essay.id },
    props: { essay },
  }));
}

const { essay } = Astro.props;
const { Content } = await render(essay);
---

<Layout title={essay.data.title}>
  <article class="max-w-prose mx-auto">
    <header class="mb-8">
      <a href={`${BASE}/daily`} class="text-sm text-primary hover:text-primary-dark mb-4 inline-block">
        ← 返回日常
      </a>
      <h1 class="text-2xl sm:text-3xl font-bold text-[#1A1A1A] mb-3 dark:text-white">
        {essay.data.title}
      </h1>
      <time datetime={essay.data.date.toISOString()} class="text-sm text-[#666666] dark:text-gray-400">
        {essay.data.date.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
    </header>

    <div class="prose prose-lg max-w-none prose-a:text-primary prose-a:no-underline hover:prose-a:text-primary-dark dark:prose-invert">
      <Content />
    </div>

    <footer class="mt-12 pt-6 border-t border-gray-200">
      <a href={`${BASE}/daily`} class="text-primary hover:text-primary-dark">
        ← 返回日常
      </a>
    </footer>
  </article>
</Layout>
